# ─── Session server ──────────────────────────────────────────────────────────
# TCP port the session server listens on (default 8787).
PORT=8787

# ─── Training dashboard ──────────────────────────────────────────────────────
# When the training dashboard (training.html) is served from a different host
# than the session server, set this to the full URL of the session server.
# Example: VITE_TRAINING_SERVER_URL=http://192.168.1.100:8787
# Leave blank to use localhost (default for desktop training).
VITE_TRAINING_SERVER_URL=
